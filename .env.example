# ─────────────────────────────────────────────────────────
# Sentinel - Environment Configuration
# ─────────────────────────────────────────────────────────

# Docker Socket (default: unix:///var/run/docker.sock)
SENTINEL_DOCKER_URL=unix:///var/run/docker.sock

# API Server
SENTINEL_API_HOST=0.0.0.0
SENTINEL_API_PORT=9120

# Rules File Path
SENTINEL_RULES_PATH=rules.yaml

# Database
SENTINEL_DB_PATH=db/sentinel.db

# Polling Interval (seconds)
SENTINEL_POLL_INTERVAL=15

# Circuit Breaker
SENTINEL_CIRCUIT_BREAKER_THRESHOLD=3
SENTINEL_CIRCUIT_BREAKER_WINDOW_MINUTES=5

# Logging
SENTINEL_LOG_LEVEL=INFO
SENTINEL_LOG_FORMAT=json

# ─── Notifier: Discord ───
SENTINEL_DISCORD_WEBHOOK_URL=

# ─── Notifier: Slack ───
SENTINEL_SLACK_WEBHOOK_URL=

# ─── Notifier: Telegram ───
SENTINEL_TELEGRAM_BOT_TOKEN=
SENTINEL_TELEGRAM_CHAT_ID=
